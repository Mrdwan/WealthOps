{
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git add -A:*)",
      "Bash(git add .:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- :*)",
      "Bash(git checkout .:*)",
      "Bash(git restore:*)",
      "Bash(git restore .:*)",
      "Edit(.env)"
    ],
    "allow": [
      "Bash(date:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git checkout -b:*)",
      "Bash(git branch:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",
      "Bash(md5:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git branch --show-current) && [ \"$branch\" != \"main\" ] && [ \"$branch\" != \"master\" ] || (echo 'BLOCKED: Cannot commit to main/master. Create a feature branch first.' && exit 1)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check --fix ."
          },
          {
            "type": "command",
            "command": "uv run ruff format ."
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["context7"]
}
