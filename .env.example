# WealthOps — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- Data Sources ---
# Tiingo API key (https://www.tiingo.com)
WEALTHOPS_TIINGO_API_KEY=

# FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html)
WEALTHOPS_FRED_API_KEY=

# --- Telegram ---
# Create a bot via @BotFather, then get your chat ID from @userinfobot
WEALTHOPS_TELEGRAM_BOT_TOKEN=
WEALTHOPS_TELEGRAM_CHAT_ID=
WEALTHOPS_TELEGRAM_HEARTBEAT_CHAT_ID=

# --- Optional Overrides ---
# Override data directory (default: ./data)
# WEALTHOPS_DATA_DIR=./data

# Override log level (default: INFO)
# WEALTHOPS_LOG_LEVEL=INFO
